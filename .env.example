# Base de datos
DB_URL=jdbc:mysql://localhost:3306/restocontrol?serverTimezone=America/Lima
DB_USERNAME=restocontrol
DB_PASSWORD=reemplazar_con_una_clave_segura

# JWT: clave Base64 de al menos 256 bits. Generar una propia antes de desplegar.
JWT_SECRET=reemplazar_con_una_clave_base64_segura
JWT_EXPIRATION_MS=86400000

# Frontend y CORS. Separar multiples origenes con comas.
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Correo de invitaciones
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
